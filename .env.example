# Database Configuration
DATABASE_URL=
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# Auth Configuration
AUTH_SECRET=

# Admin Initial Account
ADMIN_EMAIL=
ADMIN_PASSWORD=

# App URL — 站点根地址(生产环境必填,影响 og:url / 分享链接 / 版权链接 / 回调地址)
APP_URL=http://localhost:3000

# GitHub Integration
GITHUB_REPO=
GITHUB_TOKEN=

# Cron Job Secret
CRON_SECRET=

# SMTP Configuration
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=

# System
SKIP_DB_INIT=
DISABLE_HMR=

# Storage Backend — webdav | backblaze (default: webdav)
STORAGE_TYPE=

# Custom Pages — 实验性功能：自定义 HTML 页面托管
# 设置为 true 以启用侧边栏入口、路由和 API（还需配置下方存储后端变量）
CUSTOM_PAGES_ENABLED=

# WebDAV Storage Pool (only when STORAGE_TYPE=webdav or unset)
WEBDAV_URL=
WEBDAV_USER=
WEBDAV_PASS=

# Backblaze B2 Storage Pool (only when STORAGE_TYPE=backblaze)
# B2 应用程序密钥 ID（从 Backblaze 控制台获取）
B2_KEY_ID=
# B2 应用程序密钥（从 Backblaze 控制台获取）
B2_APP_KEY=
# B2 存储桶名称
B2_BUCKET=
# (可选) 自定义下载端点（如 Cloudflare CDN URL）
# 格式: https://xxx.yyy.zzz （无尾斜杠）
# rclone 说明: "The URL provided here SHOULD have the protocol and SHOULD NOT
# have a trailing slash or specify the /file/bucket subpath as rclone will
# request files with '{download_url}/file/{bucket_name}/{path}'"
# 启用后，下载请求走 CDN 而非 B2 直连（Backblaze 通过 Cloudflare 免费出口流量）
B2_DOWNLOAD_URL=

# Giscus Comments (post detail page only)
# Visit https://giscus.app/zh-CN to generate these values after enabling
# Discussions on your repository (Settings -> General -> Features).
# Leave all four blank to render a placeholder instead of the comment widget.
NEXT_PUBLIC_GISCUS_REPO=
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=
NEXT_PUBLIC_GISCUS_CATEGORY_ID=
