# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun-debug.log*

# local env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# regeneratable artifacts
lint-results.json
bun.lock
bun.lockb
.qwen/skills/**
!.qwen/skills/.gitkeep

# 构建期生成产物
/data/
!/data/pages-index.json
!/data/travel.yaml

# 构建期同步产物(由 npm run sync:pages 生成)
/pages/
*.md

# 构建期下载产物(由 npm run download-avatar 生成)
/avatar/*.jpg
/avatar/*.jpeg
/avatar/*.png
/avatar/*.webp

# 保留项目说明文件
!README.md
!**/README.md

# 保留 .qwen/agents 下所有 Markdown
!.qwen/agents/
!.qwen/agents/**/*.md

# 构建时临时禁用的路由目录（由 filter-db-routes.mjs 生成，restore-db-routes.mjs 恢复）
.disabled-routes/