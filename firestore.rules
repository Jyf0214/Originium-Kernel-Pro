rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "yifan0886@gmail.com" && request.auth.token.email_verified == true)
      );
    }
    function isEditor() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'editor' ||
        isAdmin()
      );
    }
    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }
    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string && 
             request.resource.data[field].size() >= minLen && 
             request.resource.data[field].size() <= maxLen;
    }
    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    // Domain Validators
    function isValidUser() {
      return hasOnlyAllowedFields(['uid', 'email', 'name', 'role', 'photoURL', 'createdAt']) &&
             isValidString('uid', 1, 100) &&
             isValidString('email', 3, 100) &&
             isValidString('name', 1, 100) &&
             request.resource.data.role in ['admin', 'editor', 'user'] &&
             isValidOptionalString('photoURL', 0, 500) &&
             request.resource.data.createdAt is string;
    }
    
    function isValidArticle() {
      return hasOnlyAllowedFields(['title', 'content', 'status', 'authorId', 'authorName', 'tags', 'coverImage', 'createdAt', 'updatedAt']) &&
             isValidString('title', 1, 200) &&
             isValidString('content', 1, 1000000) &&
             request.resource.data.status in ['draft', 'published'] &&
             isValidString('authorId', 1, 100) &&
             isValidString('authorName', 1, 100) &&
             request.resource.data.tags is list && request.resource.data.tags.size() <= 20 &&
             isValidOptionalString('coverImage', 0, 500) &&
             request.resource.data.createdAt is string &&
             request.resource.data.updatedAt is string;
    }

    function isValidConfig() {
      return hasOnlyAllowedFields(['githubRepo', 'githubToken', 'siteTitle', 'siteDescription']) &&
             isValidOptionalString('githubRepo', 0, 200) &&
             isValidOptionalString('githubToken', 0, 200) &&
             isValidString('siteTitle', 1, 100) &&
             isValidOptionalString('siteDescription', 0, 500);
    }

    function isValidRequest() {
      return hasOnlyAllowedFields(['type', 'status', 'userId', 'userName', 'createdAt']) &&
             request.resource.data.type in ['role_upgrade'] &&
             request.resource.data.status in ['pending', 'approved', 'rejected'] &&
             isValidString('userId', 1, 100) &&
             isValidString('userName', 1, 100) &&
             request.resource.data.createdAt is string;
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidUser() && (
        (isOwner(userId) && request.resource.data.role == 'user' && request.resource.data.uid == request.auth.uid) || 
        isAdmin()
      );
      allow update: if isAuthenticated() && isValidUser() && (
        (isOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.uid == resource.data.uid) || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /articles/{articleId} {
      allow read: if resource.data.status == 'published' || (isAuthenticated() && resource.data.authorId == request.auth.uid) || isAdmin();
      allow create: if isEditor() && isValidArticle() && request.resource.data.authorId == request.auth.uid;
      allow update: if isEditor() && isValidArticle() && (
        (resource.data.authorId == request.auth.uid && request.resource.data.authorId == resource.data.authorId) || 
        isAdmin()
      );
      allow delete: if isEditor() && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin() && isValidConfig();
    }

    match /requests/{requestId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidRequest() && request.resource.data.userId == request.auth.uid && request.resource.data.status == 'pending';
      allow update: if isAdmin() && isValidRequest() && request.resource.data.userId == resource.data.userId;
      allow delete: if isAdmin();
    }
  }
}
