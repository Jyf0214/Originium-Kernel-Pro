#!/usr/bin/env sh

# 优先使用 Nix 安装的 Node.js（Prisma 7 需要 22.12+）
if [ -d "$HOME/.nix-profile/bin" ]; then
  export PATH="$HOME/.nix-profile/bin:$PATH"
fi

echo "🚀 运行 Pre-push 检查..."
echo ""

# 1. 运行类型检查
echo "📝 运行 TypeScript 类型检查..."
npm run type-check || exit 1

# 2. 运行 lint 检查
echo "🔍 运行 ESLint 检查..."
npm run lint || exit 1

# 3. 运行完整构建
echo "🏗️ 运行完整构建..."
npm run build || exit 1

echo ""
echo "✅ Pre-push 检查通过！"
